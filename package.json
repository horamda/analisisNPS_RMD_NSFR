{
  "name": "dashboard-nivel-servicio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"node.exe scripts/vite.mjs --host 127.0.0.1\"",
    "build": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"node.exe scripts/vite.mjs build\"",
    "preview": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"node.exe scripts/vite.mjs preview --host 127.0.0.1\"",
    "start": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"node.exe server.mjs\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "devDependencies": {}
}
